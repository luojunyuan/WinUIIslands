{
  "$schema": "http://json.schemastore.org/template",
  "author": "CoreIsland",
  "classifications": ["WinUI", "Desktop", "XAML Islands"],
  "identity": "CoreIsland.App",
  "name": "CoreIsland Application",
  "description": "A XAML Islands unpackaged desktop app powered by CoreIsland. Optionally includes Microsoft.UI.Xaml (WinUI 2).",
  "shortName": "coreisland",
  "sourceName": "CoreIslandApp",
  "defaultName": "CoreIslandApp1",
  "tags": {
    "language": "C#",
    "type": "project"
  },
  "symbols": {
    "UseWinUI": {
      "type": "parameter",
      "datatype": "bool",
      "defaultValue": "false",
      "description": "Include Microsoft.UI.Xaml (WinUI 2) NuGet package reference and related XAML resources."
    },
    "CoreIslandVersion": {
      "type": "parameter",
      "datatype": "string",
      "defaultValue": "1.1.3",
      "description": "Version of the CoreIsland NuGet package.",
      "replaces": "CORESLAND_NUGET_VERSION"
    },
    "WinUIVersion": {
      "type": "parameter",
      "datatype": "string",
      "defaultValue": "2.8.7",
      "description": "Version of Microsoft.UI.Xaml (only effective when UseWinUI is true).",
      "replaces": "WINUI_NUGET_VERSION"
    }
  },
  "primaryOutputs": [
    {
      "path": "CoreIslandApp.csproj"
    }
  ],
  "postActions": [
    {
      "description": "Restore NuGet packages",
      "manualInstructions": [
        {
          "text": "Run 'dotnet restore'"
        }
      ],
      "actionId": "210D431B-A78B-4D2F-B762-4ED3E3EA9025",
      "continueOnError": true
    }
  ]
}
