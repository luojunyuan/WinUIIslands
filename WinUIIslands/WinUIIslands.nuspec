<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2012/06/nuspec.xsd">
  <metadata>
    <id>WinUIIslands</id>
    <version>1.1.1</version>
    <title>WinUIIslands</title>
    <authors>WinUIIslands</authors>
    <license type="expression">MIT</license>
    <icon>icon.png</icon>
    <readme>README.md</readme>
    <description>Build unpackaged .NET 10 desktop applications with UWP XAML, WinUI 2 controls, custom windows and NativeAOT deployment.</description>
    <tags>xaml-islands winui winui2 mux uwp xbf unpackaged net10 windows nativeaot</tags>
    <repository type="git" url="https://github.com/luojunyuan/WinUIIslands" />
    <dependencies>
      <group targetFramework="net10.0-windows10.0.26100">
        <dependency id="Microsoft.UI.Xaml" version="2.8.7" />
      </group>
    </dependencies>
    <frameworkReferences>
      <group targetFramework="net10.0-windows10.0.26100">
        <frameworkReference name="Microsoft.Windows.SDK.NET.Ref.Xaml" />
      </group>
    </frameworkReferences>
  </metadata>
  <files>
    <!-- Runtime assembly -->
    <file src="bin\Release\net10.0-windows10.0.26100.0\WinUIIslands.dll" target="lib\net10.0-windows10.0.26100\WinUIIslands.dll" />

    <!-- NuGet README (shown after install) -->
    <file src="readme.txt" target="readme.txt" />
    <file src="..\README.md" target="README.md" />
    <file src="..\assets\WinUIIslands.png" target="icon.png" />

    <!-- Auto-import wrappers (NuGet convention: build/{id}.props + build/{id}.targets) -->
    <file src="buildTransitive\WinUIIslands.props" target="buildTransitive\WinUIIslands.props" />
    <file src="buildTransitive\WinUIIslands.targets" target="buildTransitive\WinUIIslands.targets" />

    <!-- Feature files imported by the wrappers -->
    <file src="buildTransitive\WinUIIslands.XbfEmbed.props" target="buildTransitive\WinUIIslands.XbfEmbed.props" />
    <file src="buildTransitive\WinUIIslands.XbfEmbed.targets" target="buildTransitive\WinUIIslands.XbfEmbed.targets" />
    <file src="buildTransitive\WinUIIslands.Mux.props" target="buildTransitive\WinUIIslands.Mux.props" />
    <file src="buildTransitive\WinUIIslands.Mux.targets" target="buildTransitive\WinUIIslands.Mux.targets" />
    <file src="buildTransitive\WinUIIslands.AppMain.targets" target="buildTransitive\WinUIIslands.AppMain.targets" />

    <!-- Pre-trimmed WinUI 2 resources, shared by every consumer architecture -->
    <file src="buildTransitive\Mux\Microsoft.UI.Xaml.pri" target="buildTransitive\Mux\Microsoft.UI.Xaml.pri" />

    <!-- PowerShell helper (called by an MSBuild Exec task, not an init script) -->
    <file src="buildTransitive\Utils\Patch-AppMain.ps1" target="buildTransitive\Utils\Patch-AppMain.ps1" />
  </files>
</package>
