<Project>
  <!-- ==================== WinUIIslands XAML patches ==================== -->
  <Target Name="WinUIIslands_PatchAppMain"
          AfterTargets="MarkupCompilePass1"
          BeforeTargets="CoreCompile">
    <Exec Command="powershell -NoProfile -ExecutionPolicy Bypass -File &quot;$(MSBuildThisFileDirectory)Utils\Patch-AppMain.ps1&quot; -FilePath &quot;$(IntermediateOutputPath)App.g.i.cs&quot;" />
  </Target>
</Project>
