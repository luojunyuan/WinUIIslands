<Project>
  <PropertyGroup>
    <_WinUIIslandsMuxArch Condition="'$(Platform)' == 'x64'">x64</_WinUIIslandsMuxArch>
    <_WinUIIslandsMuxArch Condition="'$(Platform)' == 'ARM64' Or '$(Platform)' == 'arm64'">arm64</_WinUIIslandsMuxArch>
    <_WinUIIslandsMuxArch Condition="'$(Platform)' == 'x86'">x86</_WinUIIslandsMuxArch>
  </PropertyGroup>

  <!-- WinUI 2 is a required dependency, so always prepare its native runtime and PRI. -->
  <Target Name="WinUIIslands_PrepareMux"
          BeforeTargets="_GenerateProjectPriConfigurationFiles"
          Condition="'$(_WinUIIslandsMuxArch)' != ''">
    <Exec Condition="Exists('$(PkgMicrosoft_UI_Xaml)\tools\AppX\$(_WinUIIslandsMuxArch)\Release') And !Exists('$(IntermediateOutputPath)mux\Microsoft.UI.Xaml.dll')"
          Command="powershell -NoProfile -Command $tmp='$(IntermediateOutputPath)mux';$root='$(PkgMicrosoft_UI_Xaml)';$arch='$(_WinUIIslandsMuxArch)';$appx=@(dir &quot;$root\tools\AppX\$arch\Release\Microsoft.UI.Xaml.*.appx&quot; -ea 0);if($appx.Count -gt 0){$selected=$appx[$appx.Count-1];if(Test-Path $tmp){Remove-Item $tmp -Recurse -Force};$null=mkdir $tmp -Force;cp $selected.FullName $tmp\mux.zip -Force;Add-Type -AssemblyName System.IO.Compression.FileSystem;[System.IO.Compression.ZipFile]::ExtractToDirectory((Join-Path (Resolve-Path $tmp) 'mux.zip'),(Resolve-Path $tmp))}" />

    <ItemGroup>
      <!-- The architecture-independent, trimmed PRI is shipped with WinUIIslands. -->
      <_PriFile Include="$(MSBuildThisFileDirectory)Mux\Microsoft.UI.Xaml.pri" />
    </ItemGroup>
  </Target>

  <Target Name="WinUIIslands_StageMuxRuntime"
          AfterTargets="Build"
          DependsOnTargets="WinUIIslands_PrepareMux">
    <Copy SourceFiles="$(IntermediateOutputPath)mux\Microsoft.UI.Xaml.dll"
          DestinationFolder="$(OutputPath)"
          SkipUnchangedFiles="true"
          Condition="Exists('$(IntermediateOutputPath)mux\Microsoft.UI.Xaml.dll')" />
  </Target>

  <Target Name="WinUIIslands_CopyMuxToPublish"
          AfterTargets="Publish"
          DependsOnTargets="WinUIIslands_PrepareMux">
    <Copy SourceFiles="$(IntermediateOutputPath)mux\Microsoft.UI.Xaml.dll"
          DestinationFolder="$(PublishDir)"
          SkipUnchangedFiles="true"
          Condition="Exists('$(IntermediateOutputPath)mux\Microsoft.UI.Xaml.dll')" />
  </Target>
</Project>
