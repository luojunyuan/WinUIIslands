<Page
    x:Class="App1.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:islandTitleBar="using:CoreIsland.TitleBar"
    xmlns:local="using:App1"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <!--<Grid BorderBrush="Red" BorderThickness="1">-->

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <islandTitleBar:TitleBarControl x:Name="TitleBarRoot" Title="CoreIsland" />

        <Grid Grid.Row="1">
            <!--  Danmaku display area  -->
            <Canvas x:Name="DanmakuCanvas" />

            <!--  Bottom input bar  -->
            <StackPanel
                Margin="10"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Bottom"
                Orientation="Horizontal">
                <TextBox
                    x:Name="InputTextBox"
                    Width="300"
                    Height="32"
                    KeyDown="InputTextBox_KeyDown"
                    PlaceholderText="输入弹幕文本..." />
                <Button
                    x:Name="SendButton"
                    Width="100"
                    Height="32"
                    Margin="10,0,0,0"
                    Click="SendButton_Click"
                    Content="发送弹幕" />
            </StackPanel>
        </Grid>
    </Grid>
</Page>
